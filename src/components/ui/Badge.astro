---
import { clsx } from 'clsx';
import type { Size, Variant } from '@/types';

interface Props {
  variant?: Variant;
  size?: Size;
  class?: string;
}

const {
  variant = 'default',
  size = 'sm',
  class: className,
} = Astro.props as Props;

const variantClasses: Record<Variant, string> = {
  default:     'border-white/10 bg-white/[0.05] text-stone-200',
  primary:     'border-blue-300/18 bg-blue-400/10 text-blue-200 shadow-[0_10px_30px_-18px_rgba(96,165,250,0.95)]',
  secondary:   'border-white/10 bg-stone-100/[0.03] text-stone-300',
  ghost:       'border-transparent bg-transparent text-stone-400',
  outline:     'border-white/14 bg-transparent text-stone-200',
  destructive: 'border-red-400/20 bg-red-500/10 text-red-200',
};

const sizeClasses: Record<Size, string> = {
  xs:    'px-1.5 py-px   text-[10px]',
  sm:    'px-2   py-0.5  text-xs',
  md:    'px-2.5 py-0.5  text-xs',
  lg:    'px-3   py-1    text-sm',
  xl:    'px-4   py-1    text-sm',
  '2xl': 'px-5   py-1.5  text-base',
};
---

<span class={clsx('inline-flex items-center rounded-full border font-medium tracking-[0.01em]', variantClasses[variant], sizeClasses[size], className)}>
  <slot />
</span>
