---
import { clsx } from 'clsx';
import type { Size, Variant } from '@/types';
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'button'>, HTMLAttributes<'a'> {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  external?: boolean;
  class?: string;
}

const {
  variant = 'default',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  external = false,
  class: className,
  ...rest
} = Astro.props as Props;

const variantClasses: Record<Variant, string> = {
  default:     'border border-white/10 bg-white/[0.05] text-stone-100 hover:bg-white/[0.09]',
  primary:     'border border-blue-300/35 bg-[linear-gradient(135deg,rgba(59,130,246,0.95),rgba(37,99,235,0.95))] text-white shadow-[0_18px_45px_-22px_rgba(59,130,246,0.95)] hover:border-blue-200/50 hover:brightness-110',
  secondary:   'border border-white/10 bg-[linear-gradient(180deg,rgba(17,24,39,0.92),rgba(10,14,23,0.96))] text-stone-100 hover:bg-[linear-gradient(180deg,rgba(31,41,55,0.95),rgba(12,18,29,0.98))]',
  ghost:       'border border-transparent bg-transparent text-stone-300 hover:bg-white/[0.06] hover:text-stone-100',
  outline:     'border border-white/14 bg-white/[0.02] text-stone-100 hover:border-white/22 hover:bg-white/[0.07]',
  destructive: 'border border-red-400/30 bg-red-500/90 text-white hover:bg-red-500',
};

const sizeClasses: Record<Size, string> = {
  xs:  'h-6  px-2    text-xs   gap-1',
  sm:  'h-8  px-3    text-sm   gap-1.5',
  md:  'h-9  px-4    text-sm   gap-2',
  lg:  'h-10 px-5    text-base gap-2',
  xl:  'h-11 px-6    text-base gap-2',
  '2xl': 'h-12 px-8  text-lg  gap-2.5',
};

const base = clsx(
  'inline-flex items-center justify-center rounded-full font-medium tracking-[0.01em] transition-all duration-200 ease-out',
  'hover:-translate-y-0.5',
  'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-stone-950',
  'disabled:pointer-events-none disabled:opacity-50',
  variantClasses[variant],
  sizeClasses[size],
  className,
);

const externalAttrs = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
const disabledLinkAttrs = disabled ? { 'aria-disabled': true, tabindex: -1 } : {};
---

{href ? (
  <a href={disabled ? undefined : href} class={base} {...externalAttrs} {...disabledLinkAttrs} {...rest}>
    <slot />
    {external && !disabled && <span class="sr-only">(opens in new tab)</span>}
  </a>
) : (
  <button type={type} disabled={disabled} aria-disabled={disabled || undefined} class={base} {...rest}>
    <slot />
  </button>
)}
