---
import { clsx } from 'clsx';

interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;
---

<div
  class={clsx(
    'prose prose-stone prose-invert max-w-none',
    'prose-headings:scroll-mt-24 prose-headings:font-semibold prose-headings:tracking-[-0.02em]',
    'prose-h1:font-serif prose-h2:font-serif prose-h2:text-stone-100 prose-h3:text-stone-100',
    'prose-p:max-w-none prose-p:text-stone-300 prose-p:leading-8',
    'prose-a:text-blue-300 prose-a:no-underline hover:prose-a:underline',
    'prose-strong:text-stone-100',
    'prose-code:rounded prose-code:bg-stone-800 prose-code:px-1 prose-code:py-px prose-code:text-stone-200 prose-code:before:content-none prose-code:after:content-none',
    'prose-pre:border prose-pre:border-white/10 prose-pre:bg-stone-950/80',
    'prose-blockquote:border-blue-400/30 prose-blockquote:text-stone-300',
    'prose-hr:border-white/10',
    'prose-li:text-stone-300 prose-li:marker:text-blue-300/70',
    'prose-th:text-stone-200 prose-td:text-stone-400',
    'prose-img:rounded-2xl prose-img:border prose-img:border-white/10',
    className,
  )}
>
  <slot />
</div>
