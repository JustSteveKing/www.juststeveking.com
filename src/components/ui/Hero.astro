---
import { clsx } from 'clsx';
import Container from './Container.astro';

interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  title,
  description,
  eyebrow,
  align = 'left',
  class: className,
} = Astro.props as Props;

const hasCta = Astro.slots.has('cta');
---

<section class={clsx('section-hero border-b border-white/10 py-20 sm:py-28', className)}>
  <Container>
    <div class={clsx('max-w-2xl', align === 'center' && 'mx-auto text-center')}>
      {eyebrow && (
        <p class={clsx('eyebrow mb-5', align === 'center' && 'justify-center before:hidden')}>
          {eyebrow}
        </p>
      )}
      <h1 class="font-serif text-4xl font-semibold tracking-[-0.03em] text-stone-100 sm:text-5xl">
        {title}
      </h1>
      <p class="mt-5 lede text-pretty text-stone-300">
        {description}
      </p>
      {hasCta && (
        <div class={clsx('mt-8 flex flex-wrap gap-3', align === 'center' && 'justify-center')}>
          <slot name="cta" />
        </div>
      )}
    </div>
  </Container>
</section>
