---
import { clsx } from 'clsx';
import Container from './Container.astro';

interface Props {
  title: string;
  description: string;
  align?: 'left' | 'center';
  class?: string;
}

const {
  title,
  description,
  align = 'left',
  class: className,
} = Astro.props as Props;

const hasCta = Astro.slots.has('cta');
---

<section class={clsx('py-16 sm:py-24', className)}>
  <Container>
    <div class={clsx('max-w-2xl', align === 'center' && 'mx-auto text-center')}>
      <h1 class="text-4xl font-bold tracking-tight text-stone-100 sm:text-5xl">
        {title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-stone-400">
        {description}
      </p>
      {hasCta && (
        <div class={clsx('mt-8 flex flex-wrap gap-3', align === 'center' && 'justify-center')}>
          <slot name="cta" />
        </div>
      )}
    </div>
  </Container>
</section>
