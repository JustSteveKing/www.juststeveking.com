---
import { clsx } from 'clsx';
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'>, HTMLAttributes<'div'> {
  href?: string;
  external?: boolean;
  'aria-label'?: string;
  variant?: 'default' | 'feature' | 'muted';
  class?: string;
}

const {
  href,
  external = false,
  'aria-label': ariaLabel,
  variant = 'default',
  class: className,
  ...rest
} = Astro.props as Props;

const variantClasses = {
  default: 'surface-card',
  feature: 'surface-feature',
  muted: 'surface-muted',
};

const base = clsx(
  'group relative rounded-[var(--radius-xl)] p-6 md:p-7',
  variantClasses[variant],
  href && 'lift-hover',
  className,
);

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

{href ? (
  <a href={href} class={base} aria-label={ariaLabel} {...externalAttrs} {...rest}>
    <slot />
    {external && <span class="sr-only">(opens in new tab)</span>}
  </a>
) : (
  <div class={base} aria-label={ariaLabel} {...rest}>
    <slot />
  </div>
)}
