---
import { clsx } from 'clsx';

type Level = 1 | 2 | 3 | 4 | 5 | 6;

interface Props {
  level?: Level;
  class?: string;
}

const { level = 2, class: className } = Astro.props as Props;

const Tag = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6';

const levelClasses: Record<Level, string> = {
  1: 'font-serif text-4xl font-semibold leading-tight tracking-[-0.03em] text-stone-900 dark:text-stone-50 sm:text-5xl lg:text-6xl',
  2: 'font-serif text-3xl font-semibold leading-tight tracking-[-0.03em] text-stone-900 dark:text-stone-50 sm:text-4xl',
  3: 'text-2xl font-semibold leading-tight tracking-[-0.02em] text-stone-800 dark:text-stone-100',
  4: 'text-xl font-semibold leading-snug text-stone-800 dark:text-stone-100',
  5: 'text-lg font-medium leading-snug text-stone-800 dark:text-stone-100',
  6: 'text-base font-medium leading-snug text-stone-800 dark:text-stone-100',
};
---

<Tag class={clsx(levelClasses[level], className)}>
  <slot />
</Tag>
