---
import { clsx } from 'clsx';
import Avatar from './Avatar.astro';

interface Props {
  quote: string;
  name: string;
  role: string;
  company: string;
  avatar?: string;
  class?: string;
}

const { quote, name, role, company, avatar, class: className } = Astro.props;
---

<figure class={clsx('surface-card flex w-80 shrink-0 flex-col p-6 md:p-7', className)}>
  <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-blue-200/80">Trusted by teams</p>
  <blockquote class="mb-6 flex-1 text-sm leading-7 text-stone-200">
    &ldquo;{quote}&rdquo;
  </blockquote>
  <figcaption class="flex items-center gap-3">
    {avatar && <Avatar src={avatar} alt={name} size="sm" />}
    <div>
      <p class="text-sm font-semibold text-stone-100">{name}</p>
      <p class="text-xs text-stone-500">{role}, {company}</p>
    </div>
  </figcaption>
</figure>
