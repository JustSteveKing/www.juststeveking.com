---
import { clsx } from 'clsx';
import { siteConfig, mainNav } from '@/config';
import Container from '@/components/ui/Container.astro';

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return pathname === href || (href !== '/' && pathname.startsWith(href + '/'));
}
---

<header class="sticky top-0 z-50 border-b border-stone-800/60 bg-stone-950/90 backdrop-blur-sm">
  <Container>
    <nav class="flex h-16 items-center justify-between gap-8">

      <!-- Logo -->
      <a
        href="/"
        class="shrink-0 font-semibold text-stone-100 transition-colors hover:text-white"
      >
        {siteConfig.title}
      </a>

      <!-- Primary links — hidden on mobile -->
      <div class="hidden items-center gap-1 md:flex">
        {mainNav.map((item) => (
          <a
            href={item.href}
            class={clsx(
              'rounded-md px-3 py-1.5 text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'bg-stone-800 text-stone-100'
                : 'text-stone-400 hover:bg-stone-800/50 hover:text-stone-200',
            )}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
            {item.badge && (
              <span class="ml-1.5 rounded-full bg-blue-600 px-1.5 py-px text-[10px] font-semibold text-white">
                {item.badge}
              </span>
            )}
          </a>
        ))}

        <div class="ml-4 h-4 w-px bg-stone-800"></div>

        <button
          id="search-trigger"
          type="button"
          class="ml-2 flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium text-stone-500 transition-colors hover:bg-stone-800/50 hover:text-stone-200"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <span>Search</span>
          <kbd class="ml-2 hidden font-sans text-[10px] font-semibold text-stone-600 lg:inline-block">
            <span class="text-xs">⌘</span>K
          </kbd>
        </button>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="flex items-center justify-center rounded-md p-2 text-stone-400 transition-colors hover:bg-stone-800/50 hover:text-stone-200 md:hidden"
      >
        <span class="sr-only">Open menu</span>
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>

    </nav>
  </Container>
</header>

<!-- Full-screen mobile menu overlay -->
<div
  id="mobile-menu"
  aria-label="Mobile navigation"
  class="fixed inset-0 z-50 flex flex-col bg-stone-950 md:hidden"
  style="display: none;"
>
  <!-- Top bar matching the header height -->
  <div class="flex h-16 shrink-0 items-center justify-between border-b border-stone-800/60 px-4">
    <a
      href="/"
      class="font-semibold text-stone-100"
      id="mobile-menu-logo"
    >
      {siteConfig.title}
    </a>
    <button
      id="mobile-menu-close"
      type="button"
      class="flex items-center justify-center rounded-md p-2 text-stone-400 transition-colors hover:bg-stone-800/50 hover:text-stone-200"
    >
      <span class="sr-only">Close menu</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex flex-1 flex-col justify-center px-6">
    <ul class="space-y-2">
      {mainNav.map((item) => (
        <li>
          <a
            href={item.href}
            class={clsx(
              'flex items-center rounded-lg px-4 py-3 text-2xl font-semibold transition-colors',
              isActive(item.href)
                ? 'text-stone-100'
                : 'text-stone-500 hover:text-stone-200',
            )}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
            {item.badge && (
              <span class="ml-2 rounded-full bg-blue-600 px-2 py-px text-xs font-semibold text-white">
                {item.badge}
              </span>
            )}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Footer area -->
  <div class="shrink-0 border-t border-stone-800/60 px-6 py-6">
    <p class="text-sm text-stone-600">&copy; {new Date().getFullYear()} {siteConfig.author.name}</p>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle') as HTMLButtonElement | null;
  const closeBtn = document.getElementById('mobile-menu-close') as HTMLButtonElement | null;
  const logoLink = document.getElementById('mobile-menu-logo') as HTMLAnchorElement | null;
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const FOCUSABLE = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

  function getFocusable(): HTMLElement[] {
    return menu ? Array.from(menu.querySelectorAll<HTMLElement>(FOCUSABLE)) : [];
  }

  function openMenu() {
    if (!menu) return;
    menu.style.display = 'flex';
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    // Move focus into the menu
    const focusable = getFocusable();
    focusable[0]?.focus();
  }

  function closeMenu() {
    if (!menu) return;
    menu.style.display = 'none';
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    document.body.style.overflow = '';
    // Return focus to the toggle button
    toggle?.focus();
  }

  const searchTrigger = document.getElementById('search-trigger') as HTMLButtonElement | null;
  const commandPalette = document.getElementById('command-palette') as HTMLElement | null;
  const commandInput = document.getElementById('command-input') as HTMLInputElement | null;

  searchTrigger?.addEventListener('click', () => {
    commandPalette?.classList.remove('hidden');
    commandInput?.focus();
    document.body.style.overflow = 'hidden';
  });

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  logoLink?.addEventListener('click', closeMenu);

  // Close on any nav link click
  menu?.querySelectorAll('nav a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Escape key closes menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.style.display === 'flex') {
      closeMenu();
    }
  });

  // Focus trap
  menu?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = getFocusable();
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>
