---
import { clsx } from 'clsx';
import { siteConfig, mainNav } from '@/config';
import Container from '@/components/ui/Container.astro';

const pathname = Astro.url.pathname;

function isActive(href: string) {
  return pathname === href || (href !== '/' && pathname.startsWith(href + '/'));
}

function hasChildren(item: (typeof mainNav)[number]) {
  return Array.isArray(item.items) && item.items.length > 0;
}

function isItemActive(item: (typeof mainNav)[number]) {
  return isActive(item.href) || item.items?.some((child) => isActive(child.href));
}

function navItemClasses(item: (typeof mainNav)[number]) {
  const active = isItemActive(item);

  if (item.variant === 'cta') {
    return clsx(
      'rounded-full border px-4 py-2 text-sm font-medium transition-all duration-200',
      'border-blue-300/35 bg-[linear-gradient(135deg,rgba(59,130,246,0.95),rgba(37,99,235,0.95))] text-white shadow-[0_18px_45px_-22px_rgba(59,130,246,0.95)] hover:-translate-y-0.5 hover:border-blue-200/50 hover:brightness-110',
      active && 'brightness-110',
    );
  }

  if (item.variant === 'highlight') {
    return clsx(
      'rounded-full border px-4 py-2 text-sm font-medium transition-all duration-200',
      active
        ? 'border-blue-300/25 bg-blue-400/12 text-blue-100'
        : 'border-transparent text-blue-200/90 hover:border-blue-300/16 hover:bg-blue-400/10 hover:text-blue-100',
    );
  }

  return clsx(
    'rounded-full px-4 py-2 text-sm font-medium transition-all duration-200',
    active
      ? 'bg-white/[0.08] text-stone-100'
      : 'text-stone-400 hover:bg-white/[0.05] hover:text-stone-100',
  );
}
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-[rgba(8,9,13,0.72)] shadow-[0_20px_60px_-40px_rgba(2,6,23,0.95)] backdrop-blur-xl">
  <Container>
    <nav class="flex h-[4.5rem] items-center justify-between gap-8 py-3">

      <a
        href="/"
        class="flex shrink-0 items-center gap-3 text-stone-100 transition-colors hover:text-white"
      >
        <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-sm font-semibold text-blue-200 shadow-[0_12px_30px_-20px_rgba(59,130,246,0.8)]">
          JSK
        </span>
        <span class="flex flex-col leading-none">
          <span class="text-sm font-semibold tracking-[0.16em] text-stone-200">JustSteveKing</span>
          <span class="text-[11px] uppercase tracking-[0.22em] text-stone-500">API Stability</span>
        </span>
      </a>

      <div class="hidden items-center gap-1 md:flex">
        {mainNav.map((item) => (
          hasChildren(item) ? (
            <div class="group relative">
              <a
                href={item.href}
                class={clsx(navItemClasses(item), 'inline-flex items-center gap-1.5')}
                aria-current={isItemActive(item) ? 'page' : undefined}
              >
                <span>{item.label}</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:rotate-180 group-focus-within:rotate-180"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </a>

              <div class="invisible absolute left-0 top-full z-20 pt-3 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100">
                <div class="surface-panel min-w-60 p-2 shadow-2xl">
                  {item.items?.map((child) => (
                    <a
                      href={child.href}
                      class={clsx(
                        'block rounded-2xl px-4 py-3 text-sm transition-colors',
                        isActive(child.href)
                          ? 'bg-white/[0.08] text-stone-100'
                          : 'text-stone-400 hover:bg-white/[0.06] hover:text-stone-100',
                      )}
                      aria-current={isActive(child.href) ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class={navItemClasses(item)}
              aria-current={isItemActive(item) ? 'page' : undefined}
            >
              {item.label}
              {item.badge && (
                <span class="ml-1.5 rounded-full bg-blue-600 px-1.5 py-px text-[10px] font-semibold text-white">
                  {item.badge}
                </span>
              )}
            </a>
          )
        ))}

        <div class="ml-4 h-6 w-px bg-white/10"></div>

        <button
          id="search-trigger"
          type="button"
          class="ml-2 flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-4 py-2 text-sm font-medium text-stone-400 transition-all duration-200 hover:-translate-y-0.5 hover:bg-white/[0.06] hover:text-stone-100"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <span>Search</span>
          <kbd class="ml-2 hidden font-sans text-[10px] font-semibold text-stone-500 lg:inline-block">
            <span class="text-xs">⌘</span>K
          </kbd>
        </button>
      </div>

      <button
        id="mobile-menu-toggle"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="flex items-center justify-center rounded-full border border-white/10 bg-white/[0.03] p-3 text-stone-400 transition-colors hover:bg-white/[0.08] hover:text-stone-100 md:hidden"
      >
        <span class="sr-only">Open menu</span>
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>

    </nav>
  </Container>
</header>

<div
  id="mobile-menu"
  aria-label="Mobile navigation"
  class="fixed inset-0 z-50 flex flex-col bg-[rgba(8,9,13,0.98)] backdrop-blur-xl md:hidden"
  style="display: none;"
>
  <div class="flex h-[4.5rem] shrink-0 items-center justify-between border-b border-white/10 px-4 py-3">
    <a
      href="/"
      class="flex items-center gap-3 text-stone-100"
      id="mobile-menu-logo"
    >
      <span class="flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-sm font-semibold text-blue-200">JSK</span>
      <span class="text-sm font-semibold tracking-[0.16em]">JustSteveKing</span>
    </a>
    <button
      id="mobile-menu-close"
      type="button"
      class="flex items-center justify-center rounded-full border border-white/10 bg-white/[0.03] p-3 text-stone-400 transition-colors hover:bg-white/[0.08] hover:text-stone-100"
    >
      <span class="sr-only">Close menu</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>

  <nav class="flex-1 overflow-y-auto px-6">
    <ul class="space-y-3 py-6">
      {mainNav.map((item) => (
        <li class={clsx(hasChildren(item) && 'surface-muted rounded-[var(--radius-xl)]')}>
          {hasChildren(item) ? (
            <>
              <div class="flex items-center gap-2 p-2">
                <a
                  href={item.href}
                  class={clsx(
                    'flex min-w-0 flex-1 items-center rounded-2xl px-4 py-3 text-xl font-semibold transition-colors',
                    isItemActive(item)
                      ? 'text-stone-100'
                      : 'text-stone-300 hover:bg-white/[0.06] hover:text-white',
                  )}
                  aria-current={isItemActive(item) ? 'page' : undefined}
                >
                  <span class="truncate">{item.label}</span>
                </a>
                <button
                  type="button"
                  class="mobile-submenu-toggle flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl text-stone-400 transition-colors hover:bg-white/[0.06] hover:text-stone-100"
                  data-mobile-submenu-toggle
                  data-target={`mobile-submenu-${item.label.toLowerCase().replace(/\s+/g, '-')}`}
                  aria-expanded={isItemActive(item) ? 'true' : 'false'}
                  aria-controls={`mobile-submenu-${item.label.toLowerCase().replace(/\s+/g, '-')}`}
                >
                  <span class="sr-only">Toggle {item.label} menu</span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class={clsx(
                      'transition-transform',
                      isItemActive(item) && 'rotate-180',
                    )}
                    data-chevron
                    aria-hidden="true"
                  >
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                </button>
              </div>

              <div
                id={`mobile-submenu-${item.label.toLowerCase().replace(/\s+/g, '-')}`}
                class={clsx(
                  'space-y-1 border-t border-white/10 px-2 pb-2 pt-2',
                  !isItemActive(item) && 'hidden',
                )}
              >
                <a
                  href={item.href}
                  class={clsx(
                    'block rounded-2xl px-4 py-3 text-sm transition-colors',
                    isActive(item.href)
                      ? 'bg-white/[0.08] text-stone-100'
                      : 'text-stone-400 hover:bg-white/[0.06] hover:text-stone-100',
                  )}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  Browse {item.label}
                </a>

                {item.items?.map((child) => (
                  <a
                    href={child.href}
                    class={clsx(
                      'block rounded-2xl px-4 py-3 text-sm transition-colors',
                      isActive(child.href)
                        ? 'bg-white/[0.08] text-stone-100'
                        : 'text-stone-400 hover:bg-white/[0.06] hover:text-stone-100',
                    )}
                    aria-current={isActive(child.href) ? 'page' : undefined}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              href={item.href}
              class={clsx(
                'flex items-center rounded-[var(--radius-xl)] px-4 py-4 text-xl font-semibold transition-colors',
                item.variant === 'cta' && 'bg-[linear-gradient(135deg,rgba(59,130,246,0.95),rgba(37,99,235,0.95))] text-white',
                item.variant === 'highlight' && !isItemActive(item) && 'text-blue-200 hover:bg-blue-500/10 hover:text-blue-100',
                item.variant !== 'cta' && item.variant !== 'highlight' && !isItemActive(item) && 'text-stone-300 hover:bg-white/[0.06] hover:text-white',
                isItemActive(item) && item.variant !== 'cta' && 'bg-white/[0.08] text-stone-100',
              )}
              aria-current={isItemActive(item) ? 'page' : undefined}
            >
              {item.label}
              {item.badge && (
                <span class="ml-2 rounded-full bg-blue-600 px-2 py-px text-xs font-semibold text-white">
                  {item.badge}
                </span>
              )}
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <div class="shrink-0 border-t border-white/10 px-6 py-6">
    <p class="text-sm text-stone-500">&copy; {new Date().getFullYear()} {siteConfig.author.name}</p>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle') as HTMLButtonElement | null;
  const closeBtn = document.getElementById('mobile-menu-close') as HTMLButtonElement | null;
  const logoLink = document.getElementById('mobile-menu-logo') as HTMLAnchorElement | null;
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  const FOCUSABLE = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

  function getFocusable(): HTMLElement[] {
    return menu
      ? Array.from(menu.querySelectorAll<HTMLElement>(FOCUSABLE)).filter(
          (element) => element.getClientRects().length > 0,
        )
      : [];
  }

  function openMenu() {
    if (!menu) return;
    menu.style.display = 'flex';
    toggle?.setAttribute('aria-expanded', 'true');
    iconOpen?.classList.add('hidden');
    iconClose?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    // Move focus into the menu
    const focusable = getFocusable();
    focusable[0]?.focus();
  }

  function closeMenu() {
    if (!menu) return;
    menu.style.display = 'none';
    toggle?.setAttribute('aria-expanded', 'false');
    iconOpen?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    document.body.style.overflow = '';
    // Return focus to the toggle button
    toggle?.focus();
  }

  const searchTrigger = document.getElementById('search-trigger') as HTMLButtonElement | null;
  const commandPalette = document.getElementById('command-palette') as HTMLElement | null;
  const commandInput = document.getElementById('command-input') as HTMLInputElement | null;
  const submenuToggles = menu?.querySelectorAll<HTMLButtonElement>('[data-mobile-submenu-toggle]') ?? [];

  searchTrigger?.addEventListener('click', () => {
    commandPalette?.classList.remove('hidden');
    commandInput?.focus();
    document.body.style.overflow = 'hidden';
  });

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  logoLink?.addEventListener('click', closeMenu);

  submenuToggles.forEach((button) => {
    button.addEventListener('click', () => {
      const targetId = button.dataset.target;
      if (!targetId) return;

      const panel = document.getElementById(targetId);
      const chevron = button.querySelector<HTMLElement>('[data-chevron]');

      if (!panel) return;

      const isExpanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!isExpanded));
      panel.classList.toggle('hidden', isExpanded);
      chevron?.classList.toggle('rotate-180', !isExpanded);
    });
  });

  // Close on any nav link click
  menu?.querySelectorAll('nav a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Escape key closes menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.style.display === 'flex') {
      closeMenu();
    }
  });

  // Focus trap
  menu?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = getFocusable();
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) {
        e.preventDefault();
        last.focus();
      }
    } else {
      if (document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>
