---
import '@/styles/main.css';
import type { PageMeta } from '@/types';
import { siteConfig } from '@/config';
import { BaseHead } from '@/components/seo';
import Footer from '@/components/layout/Footer.astro';
import Nav from '@/components/layout/Nav.astro';
import CommandPalette from '@/components/ui/CommandPalette.astro';

interface Props {
  meta?: PageMeta;
}

const { meta } = Astro.props as Props;
---

<!doctype html>
<html lang={siteConfig.locale ?? 'en'} class="dark h-full scroll-smooth">
  <head>
    <BaseHead {meta} />
    <slot name="head" />
  </head>

  <body class="flex min-h-full flex-col bg-stone-950 font-sans text-stone-300 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-stone-100 focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-stone-900 focus:outline-none focus:ring-2 focus:ring-stone-500"
    >
      Skip to main content
    </a>
    <Nav />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CommandPalette />
  </body>
</html>
