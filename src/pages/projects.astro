---
import { getEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Hero, Section, Badge, Container, Heading } from '@/components';
import { projects as projectsMeta } from '@/config/pages';

const resumeEntry = await getEntry('resume', 'resume');
const projects = resumeEntry?.data.projects ?? [];

// Sort projects by startDate (most recent first)
const sortedProjects = [...projects].sort((a, b) => {
  if (!a.startDate) return 1;
  if (!b.startDate) return -1;
  return new Date(b.startDate).getTime() - new Date(a.startDate).getTime();
});
---

<Layout meta={projectsMeta}>
  <Hero title={projectsMeta.title} description={projectsMeta.description} />

  <Section class="py-12">
    <Container>
      <div class="grid gap-6 sm:grid-cols-2">
        {sortedProjects.map((project) => (
          <div
            class="group flex flex-col rounded-xl border border-stone-800 p-6 transition-colors hover:border-stone-700 hover:bg-stone-900/60"
          >
            <div class="flex items-start justify-between gap-3 mb-3">
              <Heading level={3} class="text-lg font-semibold text-stone-100 group-hover:text-white leading-snug">
                {project.name}
              </Heading>
              {project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="shrink-0 text-stone-600 group-hover:text-stone-300 transition-colors"
                  aria-label={`Visit ${project.name}`}
                >
                  <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>

            {project.description && (
              <p class="text-sm text-stone-400 leading-relaxed mb-4">
                {project.description}
              </p>
            )}

            {project.highlights.length > 0 && (
              <ul class="mb-6 space-y-2">
                {project.highlights.map((highlight) => (
                  <li class="flex items-start gap-2 text-sm text-stone-500">
                    <span class="text-stone-700 mt-1">•</span>
                    <span>{highlight}</span>
                  </li>
                ))}
              </ul>
            )}

            <div class="mt-auto pt-4 border-t border-stone-800/60">
              <div class="flex flex-wrap gap-2 mb-3">
                {project.roles.map((role) => (
                  <Badge variant="primary" size="xs">{role}</Badge>
                ))}
                {project.type && (
                  <Badge variant="secondary" size="xs">{project.type}</Badge>
                )}
              </div>
              
              {project.keywords.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {project.keywords.map((keyword) => (
                    <Badge variant="outline" size="xs">{keyword}</Badge>
                  ))}
                </div>
              )}

              {(project.startDate || project.endDate) && (
                <div class="mt-4 text-xs text-stone-600 font-mono">
                  {project.startDate && new Date(project.startDate).getFullYear()}
                  {project.endDate ? ` — ${new Date(project.endDate).getFullYear()}` : ' — Present'}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </Container>
  </Section>
</Layout>
