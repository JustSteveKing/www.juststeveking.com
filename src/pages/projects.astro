---
import { getEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import {
  Badge,
  Button,
  Card,
  Container,
  ConversionPanel,
  Heading,
  Hero,
  Section,
} from '@/components';
import { projects as projectsMeta } from '@/config/pages';

const resumeEntry = await getEntry('resume', 'resume');
const projects = resumeEntry?.data.projects ?? [];

const sortedProjects = [...projects].sort((a, b) => {
  if (!a.startDate) return 1;
  if (!b.startDate) return -1;
  return new Date(b.startDate).getTime() - new Date(a.startDate).getTime();
});

function projectOutcome(project: (typeof sortedProjects)[number]) {
  if (project.highlights[1]) return project.highlights[1];
  if (project.keywords.length > 0) {
    return `Shows how I work across ${project.keywords.slice(0, 3).join(', ')} with an emphasis on maintainable systems.`;
  }

  return 'Shows the kind of technical judgment I bring to product, platform, and API work.';
}

function projectApproach(project: (typeof sortedProjects)[number]) {
  if (project.highlights[0]) return project.highlights[0];
  if (project.roles.length > 0) {
    return `Built through a ${project.roles.join(', ').toLowerCase()} lens with a strong bias toward pragmatic execution.`;
  }

  return 'Shaped around clear data structures, practical implementation choices, and maintainability over novelty.';
}
---

<Layout meta={projectsMeta}>
  <Hero
    eyebrow="Thinking and capability"
    title="Projects that show how I solve problems, not just what I built."
    description="Each project is a signal: how I approach structure, technical trade-offs, developer experience, and turning messy requirements into maintainable systems."
  >
    <Fragment slot="cta">
      <Button href="/services" variant="primary">See services</Button>
      <Button href="/contact" variant="outline">Book a call</Button>
    </Fragment>
  </Hero>

  <Section class="border-b border-white/10 pt-12">
    <Container>
      <div class="mb-10 max-w-3xl">
        <p class="eyebrow mb-4">Reframed work</p>
        <Heading level={2} class="mb-4 text-balance">
          These projects matter because they reveal how I think.
        </Heading>
        <p class="text-base leading-8 text-stone-400">
          Instead of treating this as a portfolio gallery, I am using it as proof of problem-solving: what the project needed to solve, how I approached it, and why that kind of thinking is useful for product and platform teams.
        </p>
      </div>

      <div class="grid gap-6">
        {sortedProjects.map((project, index) => (
          <Card variant={index % 3 === 1 ? 'feature' : 'default'}>
            <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
              <div>
                <div class="mb-4 flex items-start justify-between gap-4">
                  <div>
                    <Heading level={3} class="mb-2 text-stone-100">{project.name}</Heading>
                    {(project.startDate || project.endDate) && (
                      <p class="text-xs font-medium uppercase tracking-[0.18em] text-stone-500">
                        {project.startDate && new Date(project.startDate).getFullYear()}
                        {project.endDate ? ` — ${new Date(project.endDate).getFullYear()}` : ' — Present'}
                      </p>
                    )}
                  </div>
                  {project.url && (
                    <a
                      href={project.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-stone-300 transition-colors hover:text-white"
                      aria-label={`Visit ${project.name}`}
                    >
                      Visit ↗
                    </a>
                  )}
                </div>

                <div class="mb-5 flex flex-wrap gap-2">
                  {project.roles.map((role) => (
                    <Badge variant="primary" size="xs">{role}</Badge>
                  ))}
                  {project.type && <Badge variant="secondary" size="xs">{project.type}</Badge>}
                </div>

                {project.keywords.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {project.keywords.map((keyword) => (
                      <Badge variant="outline" size="xs">{keyword}</Badge>
                    ))}
                  </div>
                )}
              </div>

              <div class="grid gap-4 md:grid-cols-3">
                <div class="rounded-[1.25rem] border border-white/10 bg-black/10 p-5">
                  <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Problem</p>
                  <p class="text-sm leading-7 text-stone-300">
                    {project.description ?? 'A product or systems problem that needed clearer structure and execution.'}
                  </p>
                </div>
                <div class="rounded-[1.25rem] border border-white/10 bg-black/10 p-5">
                  <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Approach</p>
                  <p class="text-sm leading-7 text-stone-300">{projectApproach(project)}</p>
                </div>
                <div class="rounded-[1.25rem] border border-white/10 bg-black/10 p-5">
                  <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Outcome</p>
                  <p class="text-sm leading-7 text-stone-300">{projectOutcome(project)}</p>
                </div>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      <ConversionPanel
        eyebrow="Capability to commercial intent"
        title="If the projects look like the kind of thinking your team needs, the next step is simple."
        description="Use them as proof of approach, then head to the services page or get in touch if you need help with API reliability, performance, or technical direction."
        primaryHref="/services"
        primaryLabel="See services"
        secondaryHref="/contact"
        secondaryLabel="Book a call"
      />
    </Container>
  </Section>
</Layout>
