---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import {
  Avatar,
  Badge,
  Button,
  Card,
  Container,
  Heading,
  Link,
  Section,
  Testimonial,
} from '@/components';
import { home } from '@/config/pages';
import { tracks } from '@/config/tracks';

const allArticles: CollectionEntry<'articles'>[] = await getCollection('articles');
const allTalks: CollectionEntry<'talks'>[] = await getCollection('talks');
const allPackages: CollectionEntry<'packages'>[] = await getCollection('packages');
const allTestimonials: CollectionEntry<'testimonials'>[] = await getCollection('testimonials');

const publishedArticles = allArticles
  .filter((article) => !article.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const recentArticles = publishedArticles.slice(0, 3);

const editorPicks = publishedArticles
  .filter((article) => {
    const haystack = [
      article.data.category,
      article.data.title,
      article.data.description,
      ...(article.data.tags ?? []),
    ]
      .join(' ')
      .toLowerCase();

    return (
      article.data.featured ||
      ['api', 'laravel', 'php', 'architecture'].some((term) => haystack.includes(term))
    );
  })
  .slice(0, 3);

const curatedArticles = editorPicks.length > 0 ? editorPicks : recentArticles;

const featuredTalk = [...allTalks].sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
)[0];

const featuredPackage = [...allPackages].sort((a, b) => {
  const starDelta = (b.data.stars ?? 0) - (a.data.stars ?? 0);

  if (starDelta !== 0) {
    return starDelta;
  }

  return (b.data.monthlyDownloads ?? b.data.downloads ?? 0) - (a.data.monthlyDownloads ?? a.data.downloads ?? 0);
})[0];

const featuredTestimonials = allTestimonials.slice(0, 6);

const stats = [
  {
    value: '50K+',
    label: 'developers read this site each month',
    detail: 'Practical writing for teams building with PHP, Laravel, and APIs.',
  },
  {
    value: '30+',
    label: 'talks delivered across meetups and conferences',
    detail: 'From API design workshops to architectural deep dives.',
  },
  {
    value: '15+',
    label: 'years building and leading software teams',
    detail: 'Hands-on experience spanning product delivery, enablement, and mentoring.',
  },
];

const audiencePaths = [
  {
    eyebrow: 'Here to learn?',
    title: 'Start with curated tracks instead of guessing what to read first.',
    description:
      'I have guided paths for backend engineers, platform leads, and CTOs working on API design, Laravel architecture, and team enablement.',
    href: '/start-here',
    cta: 'Explore the learning tracks',
  },
  {
    eyebrow: 'Here to hire?',
    title: 'See how I help engineering teams sharpen delivery and architecture.',
    description:
      'I run workshops, coaching sessions, and enablement projects for teams that want cleaner APIs, stronger technical habits, and better engineering decisions.',
    href: '/work-with-me',
    cta: 'See how I work with teams',
  },
];

const pillars = [
  {
    title: 'Writing',
    description:
      'Clear, practical articles on PHP, Laravel, API design, and software architecture for developers who want to level up without the fluff.',
    proof: curatedArticles[0]
      ? `Editor’s pick: ${curatedArticles[0].data.title}`
      : 'Fresh essays and walkthroughs every month.',
    href: '/articles',
    cta: 'Browse articles',
  },
  {
    title: 'Speaking',
    description:
      'Conference talks and workshops for teams that want actionable ideas on APIs, developer tooling, and modern Laravel architecture.',
    proof: featuredTalk
      ? `Recent session: ${featuredTalk.data.title}`
      : '30+ talks delivered internationally.',
    href: '/talks',
    cta: 'View talks',
  },
  {
    title: 'Open Source',
    description:
      'Libraries, experiments, and standards work shaped by real-world PHP teams and a strong bias toward maintainable systems.',
    proof: featuredPackage
      ? `Most-starred package: ${featuredPackage.data.name}${featuredPackage.data.stars ? ` • ${featuredPackage.data.stars.toLocaleString()} stars` : ''}`
      : 'Packages used across the PHP ecosystem.',
    href: '/packages',
    cta: 'Explore packages',
  },
];

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout meta={home}>

  <Section class="border-b border-stone-800/60">
    <Container>
      <div class="max-w-4xl">
        <div class="mb-8 flex items-start gap-5">
          {siteConfig.author.avatar && (
            <Avatar
              src={siteConfig.author.avatar}
              alt={siteConfig.author.name}
              size="2xl"
            />
          )}
          <div class="pt-1">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <Badge variant="primary" size="sm">PHP-FIG Core Committee</Badge>
              <Badge variant="secondary" size="sm">Technical Director</Badge>
            </div>
            <p class="text-sm text-stone-500">Steve McDougall · Wales, UK</p>
          </div>
        </div>

        <Heading level={1} class="mb-4 max-w-3xl">
          Build APIs your team can trust.
        </Heading>

        <p class="mb-6 max-w-3xl text-xl font-medium text-stone-300">
          I help engineering teams design better APIs, improve Laravel architecture, and grow developers who ship with confidence.
        </p>

        <p class="mb-8 max-w-3xl text-lg leading-relaxed text-stone-400">
          Through in-depth writing, conference talks, open source, and hands-on team engagements, I turn hard-won lessons into practical guidance you can actually use.
        </p>

        <div class="mb-10 flex flex-wrap gap-3">
          <Button href="/start-here" variant="primary" size="lg">Start Here</Button>
          <Button href="/work-with-me" variant="outline" size="lg">Work With Me</Button>
          <Button href="/newsletter" variant="ghost" size="lg">Join Code &amp; Chill</Button>
        </div>

        <div class="grid gap-4 lg:grid-cols-2">
          {audiencePaths.map((path) => (
            <Card class="flex h-full flex-col border-stone-800 bg-stone-900/30">
              <p class="mb-3 text-xs font-semibold uppercase tracking-[0.24em] text-blue-300">
                {path.eyebrow}
              </p>
              <Heading level={3} class="mb-3 text-xl">{path.title}</Heading>
              <p class="mb-6 flex-1 text-sm leading-relaxed text-stone-400">
                {path.description}
              </p>
              <Link href={path.href} underline={false} class="text-sm font-medium text-stone-200">
                {path.cta} &rarr;
              </Link>
            </Card>
          ))}
        </div>
      </div>
    </Container>
  </Section>

  <Section class="border-b border-stone-800/60 py-10">
    <Container>
      <dl class="grid gap-5 lg:grid-cols-3">
        {stats.map(({ value, label, detail }) => (
          <div class="rounded-2xl border border-stone-800 bg-stone-900/20 p-6">
            <dd class="mb-2 text-3xl font-bold tracking-tight text-stone-100">{value}</dd>
            <dt class="mb-3 text-sm font-medium text-stone-300">{label}</dt>
            <p class="text-sm leading-relaxed text-stone-500">{detail}</p>
          </div>
        ))}
      </dl>
    </Container>
  </Section>

  <Section aria-label="Start Here" class="border-b border-stone-800/60">
    <Container>
      <div class="mb-10 max-w-2xl">
        <Heading level={2} class="mb-3">Start in the right place.</Heading>
        <p class="leading-relaxed text-stone-400">
          If you are new here, use a path that matches the job you are trying to do instead of digging through the archive at random.
        </p>
      </div>

      <div class="grid gap-5 xl:grid-cols-12">
        <Card class="group flex h-full flex-col overflow-hidden border-blue-500/20 bg-gradient-to-br from-blue-500/10 via-stone-900/40 to-stone-950 xl:col-span-7 xl:row-span-2">
          <Badge variant="primary" size="sm" class="mb-4 w-fit">Start Here</Badge>
          <Heading level={3} class="mb-4 max-w-xl text-2xl">
            Pick the path that matches your role, then go deeper without the guesswork.
          </Heading>
          <p class="mb-8 max-w-2xl flex-1 text-base leading-relaxed text-stone-300">
            I have already grouped the best material for backend engineers, platform leads, and CTOs who care about APIs, Laravel architecture, and team enablement.
          </p>
          <div class="grid gap-4 md:grid-cols-3">
            {tracks.map((track) => (
              <div class="rounded-xl border border-stone-800/80 bg-stone-950/40 p-4">
                <p class="mb-2 text-sm font-semibold text-stone-100">{track.title}</p>
                <p class="text-sm leading-relaxed text-stone-400">{track.description}</p>
              </div>
            ))}
          </div>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="/start-here" variant="primary">Explore all tracks</Button>
            <Button href="/newsletter" variant="outline">Join Code &amp; Chill</Button>
          </div>
        </Card>

        {tracks.map((track) => (
          <Card href="/start-here" class="group flex h-full flex-col xl:col-span-5">
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.24em] text-blue-300">
              Track
            </p>
            <Heading level={4} class="mb-3">{track.title}</Heading>
            <p class="mb-5 text-sm leading-relaxed text-stone-400">
              {track.description}
            </p>
            <div class="mb-6 space-y-2 text-sm text-stone-500">
              {track.items.slice(0, 2).map((item) => (
                <p>{item.label}</p>
              ))}
            </div>
            <span class="mt-auto text-sm text-stone-300 transition-colors group-hover:text-white">
              Explore this path &rarr;
            </span>
          </Card>
        ))}

        <div class="rounded-2xl border border-stone-800 bg-stone-900/30 p-6 xl:col-span-7">
          <div class="mb-6 flex items-baseline justify-between gap-4">
            <Heading level={3}>Editor&rsquo;s Picks</Heading>
            <Link href="/articles" underline={false} class="text-sm">
              All articles &rarr;
            </Link>
          </div>

          <div class="divide-y divide-stone-800">
            {curatedArticles.map((article) => (
              <a
                href={`/articles/${article.id}`}
                class="group block py-5 first:pt-0 last:pb-0"
              >
                <div class="mb-2 flex flex-wrap items-center gap-2">
                  <Badge variant="primary" size="xs">{article.data.category}</Badge>
                  {(article.data.readingTime ?? article.data.minRead) && (
                    <span class="text-xs text-stone-500">
                      {article.data.readingTime ?? article.data.minRead} min read
                    </span>
                  )}
                </div>
                <Heading level={4} class="mb-2 text-base group-hover:text-white">
                  {article.data.title}
                </Heading>
                <p class="mb-3 text-sm leading-relaxed text-stone-400">
                  {article.data.description}
                </p>
                <p class="text-xs text-stone-500">{formatDate(article.data.pubDate)}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-2xl border border-stone-800 bg-stone-900/20 p-6 xl:col-span-5">
          <Badge variant="secondary" size="sm" class="mb-4">Newsletter</Badge>
          <Heading level={3} class="mb-3">Prefer a slower pace?</Heading>
          <p class="mb-6 text-sm leading-relaxed text-stone-400">
            Join 5,000+ developers reading Code &amp; Chill for weekly notes on APIs, architecture, and better technical decisions.
          </p>
          <div class="flex flex-wrap gap-3">
            <Button href="/newsletter" variant="primary">Join the newsletter</Button>
            <Button href="/articles" variant="ghost">Read the archive</Button>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <Section aria-label="Recent Writing" class="border-b border-stone-800/60">
    <Container>
      <div class="mb-10 flex items-baseline justify-between">
        <Heading level={2}>Latest Writing</Heading>
        <Link href="/articles" underline={false} class="text-sm">
          All articles &rarr;
        </Link>
      </div>

      <div class="divide-y divide-stone-800">
        {recentArticles.map((article) => (
          <a
            href={`/articles/${article.id}`}
            class="group flex flex-col gap-3 py-6 first:pt-0 last:pb-0 transition-opacity hover:opacity-90 sm:flex-row sm:items-start sm:gap-8"
          >
            <time
              datetime={new Date(article.data.pubDate).toISOString()}
              class="shrink-0 text-xs text-stone-500 sm:w-28 sm:pt-1.5"
            >
              {formatDate(article.data.pubDate)}
            </time>
            <div class="min-w-0 flex-1">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <Badge variant="primary" size="xs">{article.data.category}</Badge>
                {(article.data.readingTime ?? article.data.minRead) && (
                  <span class="text-xs text-stone-500">
                    {article.data.readingTime ?? article.data.minRead} min read
                  </span>
                )}
              </div>
              <Heading level={4} class="mb-1.5 text-base group-hover:text-white">
                {article.data.title}
              </Heading>
              <p class="line-clamp-1 text-sm leading-relaxed text-stone-400">
                {article.data.description}
              </p>
            </div>
          </a>
        ))}
      </div>
    </Container>
  </Section>

  <Section aria-label="What I Create" class="border-b border-stone-800/60">
    <Container>
      <Heading level={2} class="mb-10">What I Create</Heading>
      <div class="grid gap-5 lg:grid-cols-3">
        {pillars.map(({ title, description, proof, href, cta }) => (
          <Card href={href} class="group flex flex-col">
            <Heading level={4} class="mb-2">{title}</Heading>
            <p class="mb-5 flex-1 text-sm leading-relaxed text-stone-400">
              {description}
            </p>
            <p class="mb-5 text-xs uppercase tracking-[0.2em] text-stone-500">{proof}</p>
            <span class="text-sm text-stone-300 transition-colors group-hover:text-white">
              {cta} &rarr;
            </span>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  {featuredTestimonials.length > 0 && (
    <Section aria-label="What People Say" class="border-b border-stone-800/60">
      <Container>
        <div class="mb-10 max-w-2xl">
          <Heading level={2} class="mb-3">Trusted by developers and engineering leaders</Heading>
          <p class="leading-relaxed text-stone-400">
            The writing is useful because it comes from real delivery work, real teams, and real technical trade-offs.
          </p>
        </div>
        <div class="-mx-4 sm:-mx-6 lg:-mx-8">
          <div class="flex gap-5 overflow-x-auto px-4 pb-4 sm:px-6 lg:px-8 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
            {featuredTestimonials.map((t) => (
              <Testimonial
                quote={t.data.quote}
                name={t.data.author.name}
                role={t.data.author.role}
                company={t.data.author.company}
                avatar={t.data.author.avatar?.src}
              />
            ))}
          </div>
        </div>
      </Container>
    </Section>
  )}

  <Section aria-label="Newsletter">
    <Container>
      <div class="rounded-2xl border border-stone-800 bg-stone-900/30 p-8 md:p-10">
        <div class="max-w-2xl">
          <Badge variant="primary" class="mb-4">Newsletter</Badge>
          <Heading level={2} class="mb-3">Join 5,000+ developers reading Code &amp; Chill</Heading>
          <p class="mb-6 leading-relaxed text-stone-400">
            A weekly deep dive on APIs, Laravel architecture, and the decisions that make software easier to ship and maintain.
          </p>
          <div class="flex flex-wrap gap-3">
            <Button href="/newsletter" variant="primary">Join Code &amp; Chill</Button>
            <Button href="/rss.xml" variant="outline">Follow via RSS</Button>
          </div>
        </div>
      </div>
    </Container>
  </Section>

</Layout>
