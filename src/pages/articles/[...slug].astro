---
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render, getEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Badge, Container, Divider, Prose } from '@/components';

export const getStaticPaths: GetStaticPaths = async () => {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

interface Props {
  entry: CollectionEntry<'articles'>;
}

const { entry } = Astro.props as unknown as Props;
const { Content } = await render(entry);

const series = entry.data.series ? await getEntry(entry.data.series) : null;

const meta = {
  title: entry.data.title,
  description: entry.data.description,
  type: 'article' as const,
  ogImage: `/og/articles/${entry.id}.webp`,
  publishedTime: entry.data.pubDate,
  modifiedTime: entry.data.updatedDate,
  tags: entry.data.tags,
};
---

<Layout {meta}>
  <article>
    <header class="border-b border-stone-800 py-16 sm:py-24">
      <Container>
        <div class="max-w-3xl">
          <div class="mb-4 flex flex-wrap items-center gap-2">
            <Badge variant="primary">{entry.data.category}</Badge>
            {entry.data.tags.map((tag) => (
              <Badge variant="outline" size="xs">{tag}</Badge>
            ))}
          </div>
          <h1 class="text-4xl font-bold tracking-tight text-stone-100 sm:text-5xl">
            {entry.data.title}
          </h1>
          <p class="mt-4 text-lg text-stone-400">{entry.data.description}</p>
          <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-stone-500">
            <time datetime={new Date(entry.data.pubDate).toISOString()}>
              {new Date(entry.data.pubDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            {entry.data.readingTime && (
              <span>{entry.data.readingTime} min read</span>
            )}
            {entry.data.updatedDate && (
              <span>
                Updated {new Date(entry.data.updatedDate).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
            )}
          </div>
        </div>
      </Container>
    </header>

    <Container>
      <div class="max-w-3xl py-12">
        {series && (
          <aside class="mb-8 rounded-lg border border-stone-700 bg-stone-900/50 p-5 text-sm text-stone-400">
            This article is part of the{' '}
            <a href={`/articles/series/${series.id}`} class="text-stone-300 font-medium underline underline-offset-4 hover:text-white transition-colors">
              {series.data.title}
            </a>{' '}
            series.
          </aside>
        )}

        {entry.data.sponsor && (
          <aside class="mb-8 rounded-lg border border-stone-700 bg-stone-900/50 p-5 text-sm text-stone-400">
            This article is sponsored by{' '}
            <a href={entry.data.sponsor.url} class="text-stone-300 underline underline-offset-4" target="_blank" rel="noopener noreferrer">
              {entry.data.sponsor.name}
            </a>.
          </aside>
        )}

        {entry.data.crossPost && (
          <aside class="mb-8 rounded-lg border border-stone-700 bg-stone-900/50 p-5 text-sm text-stone-400">
            This article was originally published on{' '}
            <a href={entry.data.crossPost.originalUrl} class="text-stone-300 underline underline-offset-4" target="_blank" rel="noopener noreferrer">
              {entry.data.crossPost.originalSite}
            </a>.
          </aside>
        )}

        <Prose>
          <Content />
        </Prose>

        {entry.data.tags.length > 0 && (
          <>
            <Divider class="my-10" />
            <div class="flex flex-wrap gap-2">
              {entry.data.tags.map((tag) => (
                <Badge variant="outline" size="sm">{tag}</Badge>
              ))}
            </div>
          </>
        )}
      </div>
    </Container>
  </article>
</Layout>
