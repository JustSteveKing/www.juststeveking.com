---
import type { GetStaticPaths } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Badge, Button, Container, Prose } from '@/components';

export const getStaticPaths: GetStaticPaths = async () => {
  const podcasts = await getCollection('podcasts');
  return podcasts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

interface Props {
  entry: CollectionEntry<'podcasts'>;
}

const { entry } = Astro.props as unknown as Props;
const { Content } = await render(entry);

const meta = {
  title: entry.data.title,
  description: entry.data.description ?? entry.data.title,
};
---

<Layout {meta}>
  <article>
    <header class="border-b border-stone-800 py-16 sm:py-24">
      <Container>
        <div class="max-w-3xl">
          <Badge variant="primary" class="mb-4">Episode {entry.data.episode}</Badge>
          <h1 class="text-4xl font-bold tracking-tight text-stone-100 sm:text-5xl">
            {entry.data.title}
          </h1>
          {entry.data.description && (
            <p class="mt-4 text-lg text-stone-400">{entry.data.description}</p>
          )}
          <div class="mt-4 text-sm text-stone-500">
            <time datetime={new Date(entry.data.date).toISOString()}>
              {new Date(entry.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
          </div>
          {entry.data.url && (
            <div class="mt-8">
              <Button href={entry.data.url} variant="primary" external>Listen to episode</Button>
            </div>
          )}
        </div>
      </Container>
    </header>

    <Container>
      <div class="max-w-3xl py-12">
        <Prose>
          <Content />
        </Prose>
      </div>
    </Container>
  </article>
</Layout>
