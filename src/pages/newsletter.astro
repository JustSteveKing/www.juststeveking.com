---
import Layout from '@/layouts/Layout.astro';
import { Container, Section, Heading, Button, Badge, Card, ConversionPanel } from '@/components';
import { newsletter } from '@/config/pages';

const expectations = [
  {
    title: 'Deep dives',
    description: 'Practical essays on APIs, architecture, and the habits that make software easier to ship.',
  },
  {
    title: 'Case studies',
    description: 'Breakdowns of real technical decisions, fixes, and lessons from delivery work.',
  },
  {
    title: 'Useful opinion',
    description: 'A point of view on engineering leadership, delivery pressure, and developer experience.',
  },
];
---

<Layout meta={newsletter}>
  <Section variant="hero" class="border-b border-white/10">
    <Container>
      <div class="max-w-3xl">
        <div class="mb-5 flex flex-wrap items-center gap-3">
          <Badge variant="primary">Newsletter</Badge>
          <Badge variant="secondary">5,000+ readers</Badge>
        </div>
        <p class="eyebrow mb-4">Owned attention with better taste</p>
        <Heading level={1} class="mb-5 text-balance">Code & Chill</Heading>
        <p class="lede">
          Join 5,000+ developers who want thoughtful writing on APIs, architecture, and the decisions that make software easier to ship.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <span class="metric-chip"><strong>Weekly</strong> not constant inbox noise</span>
          <span class="metric-chip"><strong>Useful</strong> insight you can actually apply</span>
        </div>
      </div>
    </Container>
  </Section>

  <Section class="border-b border-white/10">
    <Container>
      <div class="grid gap-12 lg:grid-cols-2">
        <div class="section-intro">
          <p class="eyebrow mb-4">What you get</p>
          <Heading level={2} class="mb-4 text-balance">A quieter, more thoughtful channel than the average technical newsletter.</Heading>
          <p class="mb-8">
            This is where long-form thinking, delivery lessons, and useful frameworks land first. It is designed to build trust over time, not chase clicks.
          </p>

          <div class="grid gap-5">
            {expectations.map((item, index) => (
              <Card variant={index === 0 ? 'feature' : 'muted'} class="h-full">
                <Heading level={3} class="mb-3 text-stone-100">{item.title}</Heading>
                <p class="text-sm leading-7 text-stone-400">{item.description}</p>
              </Card>
            ))}
          </div>
        </div>

        <div class="surface-feature surface-grid glow-ring rounded-[var(--radius-xl)] p-8 shadow-sm">
          <Heading level={3} class="mb-3 text-stone-50">Subscribe</Heading>
          <p class="mb-6 text-sm leading-7 text-stone-300">
            Join once, read when it is useful, and unsubscribe whenever it stops earning the space.
          </p>
          <form 
            id="newsletter-form" 
            action="https://buttondown.com/api/emails/embed-subscribe/juststeveking" 
            method="post" 
            class="space-y-4 embeddable-buttondown-form"
          >
            <div>
              <label for="bd-email" class="sr-only">Email address</label>
              <input
                id="bd-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                class="field-shell"
                placeholder="Enter your email"
              />
            </div>
            <Button variant="primary" type="submit" class="w-full">
              Join Code & Chill
            </Button>
            <div class="text-center space-y-2">
              <p class="text-xs text-stone-400">
                No spam, just thoughtful technical writing. Unsubscribe at any time.
              </p>
              <p class="text-[10px] uppercase tracking-widest text-stone-500">
                <a href="https://buttondown.com/refer/juststeveking" target="_blank" rel="noopener noreferrer" class="hover:text-stone-400 transition-colors">
                  Powered by Buttondown.
                </a>
              </p>
            </div>
          </form>
        </div>
      </div>
    </Container>
  </Section>

  <Section>
    <Container>
      <ConversionPanel
        eyebrow="Already reading?"
        title="Use the newsletter as the slow-burn layer, then head to services when the problem becomes urgent."
        description="If you are here to learn, keep reading. If you are already dealing with an expensive API or delivery problem, the services page is the faster path."
        primaryHref="/articles"
        primaryLabel="Read latest articles"
        secondaryHref="/services"
        secondaryLabel="See services"
      />
    </Container>
  </Section>
</Layout>
