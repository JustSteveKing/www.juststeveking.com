---
import Layout from '@/layouts/Layout.astro';
import { Button, Container, Heading, Section } from '@/components';
import { workWithMe } from '@/config/pages';
---

<Layout meta={workWithMe}>
  <Section variant="hero">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-4 justify-center before:hidden">Compatibility route</p>
        <Heading level={1} class="mb-5 text-balance">Work With Me has moved to Services.</Heading>
        <p class="mb-8 text-base leading-8 text-stone-400">
          The new services page explains the offers, process, and best next step if you want help fixing API performance, reliability, or delivery bottlenecks.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <Button href="/services" variant="primary">Go to services</Button>
          <Button href="/contact" variant="outline">Book a call</Button>
        </div>
      </div>
    </Container>
  </Section>
</Layout>
