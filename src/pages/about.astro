---
import type { CollectionEntry } from 'astro:content';
import { getCollection, getEntry } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config';
import {
  Avatar,
  Badge,
  Button,
  Card,
  Container,
  ConversionPanel,
  Heading,
  Link,
  Section,
  Testimonial,
} from '@/components';
import { about } from '@/config/pages';

const resumeEntry = await getEntry('resume', 'resume');
const resume = resumeEntry?.data;
const allTestimonials: CollectionEntry<'testimonials'>[] = await getCollection('testimonials');
const featuredTestimonials = allTestimonials.slice(0, 3);

const currentRoles = resume?.work.filter((role) => !role.endDate) ?? [];

const philosophy = [
  {
    title: 'Predictability over heroics',
    description:
      'APIs should behave in ways teams can trust. The goal is not cleverness. The goal is dependable systems and calmer releases.',
  },
  {
    title: 'Diagnosis before drama',
    description:
      'Most technical problems get more expensive because teams start fixing before they understand what is actually failing.',
  },
  {
    title: 'Teaching matters',
    description:
      'A fix is better when the team understands the reasoning behind it and can repeat the decision later without outside help.',
  },
];

const trustSignals = [
  '15+ years building, leading, and improving software teams.',
  '50K+ developers reached through writing, talks, and technical education.',
  '30+ talks and workshops delivered across meetups and conferences.',
  'Contributor to standards work as a PHP-FIG Core Committee member.',
];

const milestones = [
  {
    year: '2007–2011',
    title: 'Built discipline under pressure',
    description:
      'My early career in the Royal Engineers trained the kind of systematic problem-solving and calm decision-making that still shapes how I approach engineering work.',
  },
  {
    year: '2018–2023',
    title: 'Turned teaching into leverage',
    description:
      'From founding communities to publishing technical columns and speaking internationally, I learned how to explain hard engineering ideas in ways teams can act on.',
  },
  {
    year: 'Today',
    title: 'Helping teams fix expensive technical friction',
    description:
      'My work now sits at the overlap of API quality, architecture, developer enablement, and the decisions that make delivery feel calmer.',
  },
];
---

<Layout meta={about}>
  <Section variant="hero" class="border-b border-white/10">
    <Container>
      <div class="grid gap-10 xl:grid-cols-[1fr_0.95fr] xl:items-center">
        <div class="max-w-3xl">
          <div class="mb-8 flex items-start gap-5">
            {siteConfig.author.avatar && (
              <Avatar
                src={siteConfig.author.avatar}
                alt={siteConfig.author.name}
                size="2xl"
              />
            )}
            <div class="pt-1">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                {currentRoles.slice(0, 2).map((role) => (
                  <Badge variant="primary" size="sm">{role.position}</Badge>
                ))}
              </div>
              <p class="text-sm text-stone-500">Wales, UK</p>
            </div>
          </div>

          <p class="eyebrow mb-4">Why trust me</p>
          <Heading level={1} class="mb-5 text-balance">
            I help teams diagnose and fix technical problems before they turn into expensive habits.
          </Heading>
          <p class="mb-6 lede">
            This is not a CV page. It is the short version of why people bring me in: I know how to spot friction, make the problem legible, and turn uncertainty into a clearer next step.
          </p>
          <div class="flex flex-wrap gap-3">
            <Button href="/services" variant="primary">See services</Button>
            <Button href="/contact" variant="outline">Book a call</Button>
          </div>
        </div>

        <Card variant="feature">
          <p class="kicker mb-3">Current focus</p>
          <Heading level={3} class="mb-3 text-stone-50">API quality, architecture, and developer growth.</Heading>
          <p class="mb-5 text-sm leading-7 text-stone-300">
            I work best with SaaS teams and engineering leaders trying to improve reliability, sharpen delivery habits, and make better technical decisions without disappearing into theory.
          </p>
          <ul class="space-y-3 text-sm leading-7 text-stone-200">
            {trustSignals.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-blue-300"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </Card>
      </div>
    </Container>
  </Section>

  <Section class="border-b border-white/10">
    <Container>
      <div class="mb-10 max-w-3xl">
        <p class="eyebrow mb-4">Story</p>
        <Heading level={2} class="mb-4 text-balance">
          My background is a mix of systems thinking, teaching, and delivery leadership.
        </Heading>
        <p class="text-base leading-8 text-stone-400">
          That combination is why the work tends to land well with teams that need more than implementation. They need diagnosis, prioritisation, and a way to explain the path forward clearly.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-3">
        {milestones.map((milestone, index) => (
          <Card variant={index === 1 ? 'feature' : 'default'} class="h-full">
            <p class="mb-3 text-sm font-semibold text-blue-200">{milestone.year}</p>
            <Heading level={3} class="mb-3 text-stone-100">{milestone.title}</Heading>
            <p class="text-sm leading-7 text-stone-400">{milestone.description}</p>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  <Section variant="band" class="border-b border-white/10">
    <Container>
      <div class="mb-10 max-w-3xl">
        <p class="eyebrow mb-4">Philosophy</p>
        <Heading level={2} class="mb-4 text-balance">
          The way I think about engineering work
        </Heading>
      </div>

      <div class="grid gap-5 lg:grid-cols-3">
        {philosophy.map((item) => (
          <Card variant="muted" class="h-full">
            <Heading level={3} class="mb-3 text-stone-100">{item.title}</Heading>
            <p class="text-sm leading-7 text-stone-400">{item.description}</p>
          </Card>
        ))}
      </div>
    </Container>
  </Section>

  {featuredTestimonials.length > 0 && (
    <Section class="border-b border-white/10">
      <Container>
        <div class="mb-10 max-w-3xl">
          <p class="eyebrow mb-4">Social proof</p>
          <Heading level={2} class="mb-4 text-balance">
            The strongest signal is usually what people say after the work.
          </Heading>
        </div>

        <div class="grid gap-5 lg:grid-cols-3">
          {featuredTestimonials.map((testimonial) => (
            <Testimonial
              quote={testimonial.data.quote}
              name={testimonial.data.author.name}
              role={testimonial.data.author.role}
              company={testimonial.data.author.company}
              avatar={testimonial.data.author.avatar?.src}
              class="h-full w-full"
            />
          ))}
        </div>
      </Container>
    </Section>
  )}

  <Section>
    <Container>
      <div class="grid gap-6 lg:grid-cols-[1fr_0.95fr]">
        <Card variant="default">
          <p class="kicker mb-3">Why clients hire me</p>
          <Heading level={3} class="mb-3 text-stone-100">Because the technical problem is rarely just technical.</Heading>
          <p class="mb-5 text-sm leading-7 text-stone-400">
            Teams usually reach out when slow APIs, messy delivery, or architecture uncertainty have started affecting confidence. They need someone who can diagnose the issue, make the trade-offs clearer, and help the team move with less friction.
          </p>
          <div class="flex flex-wrap gap-4 text-sm">
            <Link href="/services" underline={false} class="text-blue-200">View services &rarr;</Link>
            <Link href="/projects" underline={false}>See how I think &rarr;</Link>
          </div>
        </Card>

        <ConversionPanel
          compact
          eyebrow="Next step"
          title="If that sounds like the kind of help you need, let’s talk."
          description="Send a little context on the team and the technical friction you are dealing with. I will tell you what the most useful next step looks like."
          primaryHref="/contact"
          primaryLabel="Book a call"
          secondaryHref="/services"
          secondaryLabel="See the offers"
        />
      </div>
    </Container>
  </Section>
</Layout>
