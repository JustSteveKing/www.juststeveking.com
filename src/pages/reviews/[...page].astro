---
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Badge, Container, Hero, Section } from '@/components';
import { reviews as reviewsMeta } from '@/config/pages';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allReviews = await getCollection('reviews');
  const sorted = allReviews.sort(
    (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  );

  return paginate(sorted, { pageSize: 12 });
};

interface Props {
  page: Page<CollectionEntry<'reviews'>>;
}

const { page } = Astro.props as Props;
---

<Layout meta={reviewsMeta}>
  <Hero title={reviewsMeta.title} description={reviewsMeta.description} />

  <Section class="py-12">
    <Container>

      <div class="divide-y divide-stone-800">
        {page.data.map((review) => {
          return (
            <a
              href={`/reviews/${review.id}`}
              class="group flex flex-col gap-3 py-8 first:pt-0 last:pb-0 transition-opacity hover:opacity-90 sm:flex-row sm:items-start sm:gap-8"
            >
              <time
                datetime={new Date(review.data.pubDate).toISOString()}
                class="shrink-0 text-xs text-stone-500 sm:w-28 sm:pt-1.5"
              >
                {new Date(review.data.pubDate).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>

              <div class="min-w-0 flex-1">
                <div class="mb-2 flex flex-wrap items-center gap-2">
                  <Badge variant="primary">{review.data.badge}</Badge>
                  <span class="text-xs text-stone-500">{review.data.subject}</span>
                </div>
                <h2 class="mb-2 text-lg font-semibold leading-snug text-stone-100 group-hover:text-white">
                  {review.data.title}
                </h2>
                <p class="mb-3 text-sm leading-relaxed text-stone-400 line-clamp-2">
                  {review.data.description}
                </p>
                {review.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {review.data.tags.map((tag) => (
                      <Badge variant="outline" size="xs">{tag}</Badge>
                    ))}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>

      {(page.url.prev || page.url.next) && (
        <nav aria-label="Pagination" class="mt-16 flex items-center justify-between border-t border-stone-800 pt-8">
          <div>
            {page.url.prev && <a class="text-sm text-stone-300 hover:text-white" href={page.url.prev}>&larr; Newer</a>}
          </div>

          <span class="text-sm text-stone-500">
            Page {page.currentPage} of {page.lastPage}
          </span>

          <div>
            {page.url.next && <a class="text-sm text-stone-300 hover:text-white" href={page.url.next}>Older &rarr;</a>}
          </div>
        </nav>
      )}
    </Container>
  </Section>
</Layout>
