---
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import { Hero, Section, Badge, Container, Button } from '@/components';
import { packages } from '@/config/pages';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPackages = await getCollection('packages');

  const sorted = allPackages.sort((a, b) => {
    if (a.data.order !== undefined && b.data.order !== undefined) {
      return a.data.order - b.data.order;
    }
    if (a.data.order !== undefined) return -1;
    if (b.data.order !== undefined) return 1;
    return a.data.name.localeCompare(b.data.name);
  });

  return paginate(sorted, { pageSize: 12 });
};

interface Props {
  page: Page<CollectionEntry<'packages'>>;
}

const { page } = Astro.props as unknown as Props;
---

<Layout meta={packages}>
  <Hero title={packages.title} description={packages.description} />

  <Section class="py-12">
    <Container>
      <div class="grid gap-5 sm:grid-cols-2">
        {page.data.map((pkg) => (
          <a
            href={pkg.data.github ?? pkg.data.packagist ?? pkg.data.link}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col rounded-xl border border-stone-800 p-5 transition-colors hover:border-stone-700 hover:bg-stone-900/60"
          >
            <div class="flex items-start justify-between gap-3 mb-2">
              <h2 class="text-base font-semibold text-stone-100 group-hover:text-white leading-snug">
                {pkg.data.name}
              </h2>
              <span class="shrink-0 text-stone-600 group-hover:text-stone-300 transition-colors" aria-hidden="true">
                ↗
              </span>
            </div>
            <p class="text-sm text-stone-400 leading-relaxed flex-1">
              {pkg.data.description}
            </p>
            <div class="mt-4 pt-3 border-t border-stone-800/60 flex flex-wrap items-center justify-between gap-2">
              <div class="flex flex-wrap gap-1.5">
                {pkg.data.tech && pkg.data.tech.map((t) => (
                  <Badge variant="outline" size="xs">{t}</Badge>
                ))}
              </div>
              <div class="flex flex-wrap items-center gap-3 text-xs text-stone-500 ml-auto">
                {pkg.data.version && <span>v{pkg.data.version}</span>}
                {pkg.data.stars !== undefined && <span>★ {pkg.data.stars.toLocaleString()}</span>}
                {pkg.data.monthlyDownloads !== undefined && (
                  <span>↓ {pkg.data.monthlyDownloads.toLocaleString()}/mo</span>
                )}
                {pkg.data.monthlyDownloads === undefined && pkg.data.downloads !== undefined && (
                  <span>↓ {pkg.data.downloads.toLocaleString()}</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>

      {(page.url.prev || page.url.next) && (
        <nav
          aria-label="Pagination"
          class="mt-16 flex items-center justify-between border-t border-stone-800 pt-8"
        >
          <div>
            {page.url.prev && (
              <Button href={page.url.prev} variant="outline">&larr; Previous</Button>
            )}
          </div>
          <span class="text-sm text-stone-500">
            Page {page.currentPage} of {page.lastPage}
          </span>
          <div>
            {page.url.next && (
              <Button href={page.url.next} variant="outline">Next &rarr;</Button>
            )}
          </div>
        </nav>
      )}
    </Container>
  </Section>
</Layout>
